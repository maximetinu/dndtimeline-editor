# .env.example — copy to .env and fill; .env is git-ignored. Revoke the PAT after setup.
SUPABASE_PAT=                 # Personal Access Token (local only)
SUPABASE_PROJECT_REF=         # existing project ref
SUPABASE_URL=                 # https://<ref>.supabase.co
SUPABASE_ANON_KEY=            # public, also lives in js/config.js
SUPABASE_SERVICE_ROLE=        # admin key — local only, never commit
SHARED_EDITOR_EMAIL=campaign@dndtimeline.local
SHARED_EDITOR_PASSWORD=       # the campaign password (local only)
# Schema is applied via the Management API query endpoint (no DB password / psql needed).
